# =============================================================================
# .env.template — Variables d'environnement pour Luciole NVFP4 (TensorRT-LLM / GX10)
# Copiez ce fichier en .env et remplissez les valeurs
# =============================================================================

# ── Instance ──────────────────────────────────────────────────────────────────
INSTANCE_NAME=luciole

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Europe/Paris

# ── Ports exposés ─────────────────────────────────────────────────────────────
TRT_PORT=8001           # Port hôte pour TensorRT-LLM / Triton
API_PORT=8000           # Agent principal
ADMIN_PORT=8080         # Admin UI
CHAT_PORT=8501          # Chat UI
FEEDBACK_PORT=8503      # Feedback UI
QDRANT_PORT=6333        # Qdrant vectorDB
OPENSEARCH_PORT=9200    # OpenSearch
WATCHER_PORT=8090       # Watcher
MAIL_SMTP_PORT=25
MAIL_IMAP_PORT=143
MAIL_ADMIN_PORT=8025

# ── TensorRT-LLM ─────────────────────────────────────────────────────────────
# URL interne (réseau Docker) — ne pas modifier sauf changement d'architecture
LLM_URL=http://tensorrt-llm:8000
# ⚠ GX10/GB10 : mémoire UNIFIÉE 128 Go partagée CPU+GPU. NE JAMAIS mettre 0.90
# (affame l'OS, fige la machine). Reste entre 0.60 et 0.70.
KV_CACHE_FREE_GPU_MEM_FRACTION=0.70
# Taille max du batch d'inférence
MAX_BATCH_SIZE=8

# ── Sécurité mail ─────────────────────────────────────────────────────────────
MAIL_ENCRYPTION_KEY=

# ── Multi-index ──────────────────────────────────────────────────────────────
# true  → l'agent et le watcher utilisent le sous-dossier comme index
#         (ex: data/chavenay/ → collection 'chavenay')
# false → comportement mono-instance (tout dans INSTANCE_NAME)
MULTI_INDEX_MODE=false

# ── Watcher ───────────────────────────────────────────────────────────────────
WATCHER_ENABLED=true
